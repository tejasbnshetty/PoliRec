<?xml version="1.0" encoding="utf-8"?>


<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DashboardAdmin"
    android:background="@android:color/white"
    android:padding="16dp">

    <!-- Top Left: Profile Icon -->
    <ImageButton
        android:id="@+id/user_profile_admin"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/baseline_person_pin_24"
        android:background="@android:color/transparent"
        android:contentDescription="Profile"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:tint="@color/primary_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp" />

    <!-- Top Right: Notifications Icon -->
    <ImageButton
        android:id="@+id/notification_admin"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/baseline_circle_notifications_24"
        android:background="@android:color/transparent"
        android:contentDescription="Notifications"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:tint="@color/primary_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

    <!-- Welcome Message -->
    <TextView
        android:id="@+id/Welcome_admin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/user_profile_admin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/admin_search_input_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:hint="Search License Number"
        app:startIconDrawable="@drawable/baseline_search_24"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/primary_blue"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:hintTextColor="@color/primary_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/Welcome_admin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/search_bar_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@android:color/black"
            android:textColorHint="@color/primary_blue"
            android:padding="8dp" />
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/search_button_admin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/light_blue"
        app:cornerRadius="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/admin_search_input_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <com.google.android.material.button.MaterialButton
        android:id="@+id/search_button_advanced"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="85dp"
        android:backgroundTint="@color/primary_blue"
        android:text="Advanced search"
        android:textColor="@android:color/white"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/admin_search_input_layout" />


    <!-- Policy Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/policy_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Policies"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/primary_blue"
        app:cornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>


