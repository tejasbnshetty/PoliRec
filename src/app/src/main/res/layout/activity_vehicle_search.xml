<?xml version="1.0" encoding="utf-8"?>



<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Stylized Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/advanced_search_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter search"
        app:startIconDrawable="@drawable/baseline_search_24"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/primary_blue"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/advanced_search_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:textColorHint="@color/primary_blue" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Search Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/advanced_search_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SEARCH"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/primary_blue"
        app:cornerRadius="12dp" />

    <!-- Hint Texts -->
    <TextView
        android:id="@+id/search_hint_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use filters like make:Toyota model:&quot;Corolla&quot; type:SUV"
        android:textSize="14sp"
        android:textColor="@color/text_light"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/search_hint_text2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Case Insensitive. Multi-word searches must be in quotes. Others can or don't. No space after :"
        android:textSize="14sp"
        android:textColor="@color/text_light"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/searching_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Searching..."
        android:textSize="16sp"
        android:textColor="@android:color/holo_blue_dark"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        />

    <TextView
        android:id="@+id/search_result_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:layout_gravity="end"
        android:text="Results: 0" />

    <!-- ScrollView for results -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:importantForAccessibility="no">

        <LinearLayout
            android:id="@+id/results_container"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </ScrollView>

</LinearLayout>
