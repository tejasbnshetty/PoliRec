

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="8dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="6dp"
    android:backgroundTint="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/rego_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rego: "
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue" />

        <TextView
            android:id="@+id/vehicle_make"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Make: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/vehicle_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/vehicle_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/vehicle_fuel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fuel: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/vehicle_transmission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tranmission: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/registered_on"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registered On: "
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/registration_status_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expiration "
            android:textSize="15sp"
            android:textStyle="italic"
            android:textColor="@color/status_warning_green"
            android:layout_marginTop="6dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
